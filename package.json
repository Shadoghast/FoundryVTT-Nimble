{
	"name": "nimble",
	"version": "0.8.8",
	"description": "An official implementation of Nimble 2 for Foundry Virtual Tabletop.",
	"main": "nimble.mjs",
	"type": "module",
	"packageManager": "pnpm@10.11.0",
	"scripts": {
		"preinstall": "npx only-allow pnpm",
		"build": "pnpm build:compendia && vite build",
		"build:system": "vite build",
		"build:compendia": "node ./build/buildCompendia.mjs",
		"worktree:setup": "node ./build/worktreeSetup.mjs",
		"worktree:cleanup": "node ./build/worktreeCleanup.mjs",
		"worktree:reset": "pnpm worktree:cleanup && pnpm worktree:setup",
		"dev": "vite",
		"format": "biome format --write ./src/ ./types/ ./lib/ && prettier --write \"src/**/*.svelte\"",
		"format:biome": "biome format --write ./src/ ./types/ ./lib/",
		"format:svelte": "prettier --write \"src/**/*.svelte\"",
		"format:scss": "stylelint \"src/**/*.scss\" --fix",
		"lint:svelte": "eslint \"src/**/*.svelte\"",
		"lint:svelte-fix": "eslint \"src/**/*.svelte\" --fix",
		"lint": "pnpm lint:svelte && biome lint ./src/ ./types/ ./lib/",
		"lint-fix": "pnpm lint:svelte-fix && biome lint --write ./src/ ./types/ ./lib/",
		"check:svelte": "svelte-check --tsconfig ./tsconfig.json",
		"circular-deps": "depcruise --config .dependency-cruiser.cjs ./src/",
		"type-check": "tsc --noEmit",
		"check": "pnpm format && pnpm lint && pnpm circular-deps && pnpm type-check && pnpm test",
		"spell-check": "cspell -c ./cspell.json lint . --words-only | sort -u",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:ui": "vitest --ui",
		"test:coverage": "vitest run --coverage",
		"prepare": "lefthook install",
		"release": "node build/release.mjs",
		"lang:reconcile": "node scripts/reconcile-languages.mjs",
		"lang:detect-untranslated": "node scripts/detect-untranslated.mjs",
		"lang:build-compendium-skeletons": "node build/buildBabeleSkeletons.mjs",
		"audit:rules-choices": "node build/scripts/audit-rule-choices.mjs"
	},
	"imports": {
		"#documents/*": "./src/documents/*",
		"#lib/*": "./lib/*",
		"#managers/*": "./src/managers/*",
		"#stores/*": "./src/stores/*",
		"#system": "./src/utils/systemId.ts",
		"#types/*": "./types/*",
		"#utils/*": "./src/utils/*",
		"#view/*": "./src/view/*"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Nimble-Co/FoundryVTT-Nimble.git"
	},
	"authors": [
		{
			"name": "Trevor Carlston",
			"email": "trevlar@questluminary.com",
			"url": "https://ko-fi.com/questluminary"
		},
		{
			"name": "Phillip Best",
			"email": "me@phillip.best",
			"url": "https://bio.link/philbest"
		},
		{
			"name": "NekroDarkmoon",
			"url": "https://github.com/NekroDarkmoon/"
		}
	],
	"funding": [
		{
			"type": "patreon",
			"url": "https://www.patreon.com/QuestLuminary"
		},
		{
			"type": "individual",
			"url": "https://ko-fi.com/philbest"
		},
		{
			"type": "individual",
			"url": "https://ko-fi.com/nekrodarkmoon"
		},
		{
			"type": "individual",
			"url": "https://ko-fi.com/questluminary"
		}
	],
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/Nimble-Co/FoundryVTT-Nimble/issues"
	},
	"homepage": "https://github.com/Nimble-Co/FoundryVTT-Nimble#readme",
	"private": true,
	"engines": {
		"node": ">=22.1.0",
		"pnpm": ">=10.0.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@evilmartians/lefthook",
			"@parcel/watcher",
			"classic-level",
			"esbuild",
			"svelte-preprocess"
		]
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.1",
		"@eslint/js": "^9.39.2",
		"@evilmartians/lefthook": "^2.1.1",
		"@sveltejs/vite-plugin-svelte": "6.2.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.2.8",
		"@tsconfig/svelte": "^5.0.5",
		"@types/node": "^24.9.1",
		"@typescript-eslint/eslint-plugin": "^8.46.2",
		"@typescript-eslint/parser": "^8.46.2",
		"@vitest/ui": "^4.0.8",
		"classic-level": "^1.4.1",
		"dependency-cruiser": "^16.10.0",
		"eslint": "^9.38.0",
		"eslint-plugin-svelte": "^3.12.5",
		"fvtt-types": "npm:@league-of-foundry-developers/foundry-vtt-types@13.346.0-beta.20251209192131",
		"glob": "^11.0.3",
		"globals": "^16.4.0",
		"happy-dom": "^20.0.10",
		"lint-staged": "^16.2.6",
		"patch-package": "^8.0.1",
		"postcss": "^8.5.6",
		"prettier": "^3.6.2",
		"prettier-plugin-svelte": "^3.4.0",
		"sass": "^1.93.2",
		"stylelint": "^16.25.0",
		"stylelint-config-sass-guidelines": "^12.1.0",
		"svelte-check": "^4.3.3",
		"svelte-eslint-parser": "^1.4.0",
		"svelte-range-slider-pips": "^4.1.0",
		"vite": "^7.1.12",
		"vitest": "^4.0.8"
	},
	"dependencies": {
		"jspdf": "^4.2.1",
		"picomatch": "^4.0.3",
		"svelte": "^5.42.2",
		"svelte-preprocess": "^6.0.3",
		"typescript": "^5.9.3"
	}
}
